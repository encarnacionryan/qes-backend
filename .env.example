APP_NAME="Q.E.S"
APP_ENV=local
APP_KEY=base64:kL4ax5urfEdBcdMQbfHdPCWAkmuhpS3TWQdK7NgFL4k=
APP_DEBUG=true

# IMPORTANT for local hotspot deployment:
# Set this to the server machine's LAN IP (not localhost/127.0.0.1) so the
# mobile app and other devices on the hotspot can reach it, e.g.:
# APP_URL=http://192.168.4.1:8000
APP_URL=http://192.168.8.33:8000

APP_LOCALE=en
APP_TIMEZONE="Asia/Manila"

LOG_CHANNEL=stack
LOG_LEVEL=debug


DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qes
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# For the Inertia web app served from the same host as the API on the LAN:
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,192.168.4.1

QUEUE_CONNECTION=database
CACHE_STORE=file

# No internet dependency: mail/broadcast are optional and unused for core
# grading/exam flows (see SRS 2.5 constraints).
MAIL_MAILER=log
BROADCAST_CONNECTION=log

VITE_APP_NAME="${APP_NAME}"
